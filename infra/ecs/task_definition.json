{
  "family": "enterprise-ai-ops-copilot",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "2048",
  "executionRoleArn": "${ExecutionRoleArn}",
  "taskRoleArn": "${TaskRoleArn}",
  "containerDefinitions": [
    {
      "name": "api",
      "image": "${DockerImageUri}",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "APP_ENV", "value": "production" },
        { "name": "LOG_LEVEL", "value": "INFO" },
        { "name": "AWS_REGION", "value": "${AwsRegion}" },
        { "name": "VECTOR_STORE_TYPE", "value": "opensearch" },
        { "name": "OPENSEARCH_INDEX", "value": "enterprise-ops" },
        { "name": "SERVICENOW_MOCK", "value": "false" },
        { "name": "SNOWFLAKE_MOCK", "value": "false" },
        { "name": "TEAMS_MOCK", "value": "false" }
      ],
      "secrets": [
        { "name": "OPENSEARCH_ENDPOINT", "valueFrom": "${OpenSearchEndpointSsmArn}" },
        { "name": "BEDROCK_CHAT_MODEL_ID", "valueFrom": "${BedrockChatModelSsmArn}" },
        { "name": "BEDROCK_EMBEDDING_MODEL_ID", "valueFrom": "${BedrockEmbeddingModelSsmArn}" },
        { "name": "BEDROCK_GUARDRAIL_ID", "valueFrom": "${BedrockGuardrailSsmArn}" },
        { "name": "SERVICENOW_PASSWORD", "valueFrom": "${ServiceNowSecretArn}" },
        { "name": "SNOWFLAKE_PASSWORD", "valueFrom": "${SnowflakeSecretArn}" },
        { "name": "TEAMS_WEBHOOK_URL", "valueFrom": "${TeamsWebhookSecretArn}" }
      ],
      "healthCheck": {
        "command": ["CMD-SHELL", "curl -f http://localhost:8000/health || exit 1"],
        "interval": 30,
        "timeout": 10,
        "retries": 3,
        "startPeriod": 20
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/enterprise-ai-ops-copilot",
          "awslogs-region": "${AwsRegion}",
          "awslogs-stream-prefix": "api"
        }
      }
    }
  ]
}
